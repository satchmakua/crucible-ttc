# Copy to `.env` and fill in real values. `.env` is gitignored; this file is not.
# None of these are needed for the M0 mock path (`--policy mock`); they configure the
# real inference backends used from M1 onward.

# --- Ollama backend (default; native Windows) ---
# Base URL of a running Ollama server. Default if unset: http://localhost:11434
# OLLAMA_HOST=http://localhost:11434

# --- Hosted OpenAI-compatible backend (optional third backend) ---
# Used only with `--policy hosted`. Point at any OpenAI-compatible endpoint.
# CRUCIBLE_HOSTED_BASE_URL=https://api.openai.com/v1
# CRUCIBLE_HOSTED_API_KEY=sk-your-key-here

# --- HuggingFace (optional) ---
# Token for gated datasets/models, and a custom cache dir to keep downloads in-repo.
# HF_TOKEN=hf_your-token-here
# HF_HOME=.hf_cache
